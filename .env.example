# Hyperliquid API (data collection)
HL_API_URL=https://api.hyperliquid.xyz
HL_MAINNET=true

# Production DB (read-only, for trade outcome export)
PROD_DATABASE_URL=postgresql://user:pass@host:5432/wallet_backend_unified

# Weights & Biases (training logging)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=moleapp-rl

# R2/S3 (model artifact storage)
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=moleapp-models

# RunPod
RUNPOD_API_KEY=your_runpod_key

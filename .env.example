# Hyperliquid API (data collection)
HL_API_URL=https://api.hyperliquid.xyz
HL_MAINNET=true

# Production DB (read-only, for trade outcome export)
PROD_DATABASE_URL=postgresql://user:pass@host:5432/wallet_backend_unified

# Weights & Biases (training logging + dataset artifacts)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=moleapp-rl
WANDB_ENTITY=                    # Optional: W&B team/org name

# Cloudflare R2 (raw OHLCV/funding/OI parquet dumps)
R2_ENDPOINT_URL=https://9507330fe5a8c228ea49f6e5c6c6b659.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=moleapp-rl-data

# Binance Vision (no API key needed — public static dumps)
# Raw CSVs saved to data/raw/binance/ as backup
BINANCE_RAW_DIR=data/raw/binance

# RunPod
RUNPOD_API_KEY=your_runpod_key
